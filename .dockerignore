# Dependencies & build output (regenerated inside the image)
**/node_modules
**/dist
**/.next
**/coverage
**/*.tsbuildinfo

# VCS & local env
**/.git
**/.gitignore
**/.env
**/.env.*
!**/.env.example

# Logs & OS junk
**/*.log
**/.DS_Store

# NOTE: do not exclude source workspaces (apps/*, packages/*) here — this
# .dockerignore is shared by every image build from the repo root, and the
# frontend Dockerfile copies apps/frontend. The big artifacts (node_modules,
# .next, dist, .git) are already excluded above, which is where the savings are.

# Tooling & CI
.github
.claude
.vscode
nginx
docker-compose.yml
deploy.sh
scripts

# Tests & fixtures (not needed in the runtime image)
**/test
**/__tests__
**/e2e
**/*.spec.ts
**/*.test.ts

# Docs & misc
**/*.md
generate-help-pdf.py
TEST_REPORT.md
