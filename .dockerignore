# Dependencies & build output (regenerated inside the image)
**/node_modules
**/dist
**/.next
**/coverage
**/*.tsbuildinfo

# VCS & local env
**/.git
**/.gitignore
**/.env
**/.env.*
!**/.env.example

# Logs & OS junk
**/*.log
**/.DS_Store

# Unrelated workspaces (backend image doesn't need them)
apps/frontend
packages

# Tooling & CI
.github
.claude
.vscode
nginx
docker-compose.yml
deploy.sh
scripts

# Tests & fixtures (not needed in the runtime image)
**/test
**/__tests__
**/e2e
**/*.spec.ts
**/*.test.ts

# Docs & misc
**/*.md
generate-help-pdf.py
TEST_REPORT.md
