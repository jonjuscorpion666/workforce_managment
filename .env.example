# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://workforce_user:CHANGE_ME@postgres:5432/workforce_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=workforce_db
DB_USER=workforce_user
DB_PASS=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200

# ── Auth (generate with: openssl rand -base64 64) ────────────────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=CHANGE_ME_different_from_jwt_secret
REFRESH_TOKEN_EXPIRY=30d

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
NEXT_PUBLIC_APP_NAME="Workforce Transformation Platform"

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://your-domain.com

# ── Email Notifications ───────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourcompany.com

# ── AI / NLP (Optional) ───────────────────────────────────────────────────────
# Used by the AI survey question generator (POST /surveys/ai-generate)
ANTHROPIC_API_KEY=

# ── Escalation ────────────────────────────────────────────────────────────────
ESCALATION_CHECK_INTERVAL_MINUTES=60
INACTIVITY_THRESHOLD_DAYS=3
OVERDUE_CHECK_INTERVAL_MINUTES=30
