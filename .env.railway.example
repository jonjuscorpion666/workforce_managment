# ─────────────────────────────────────────────────────────────────────────────
# Railway Environment Variables
# Copy each block into the corresponding Railway service's Variables tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── BACKEND SERVICE ──────────────────────────────────────────────────────────
# (Railway auto-provides DATABASE_URL and REDIS_URL from attached plugins)

NODE_ENV=production
PORT=3001

# Set to your Railway frontend service URL, e.g. https://workforce-frontend.up.railway.app
CORS_ORIGINS=https://your-frontend.up.railway.app

JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=change-me-refresh-secret-also-long
REFRESH_TOKEN_EXPIRY=30d

# Railway injects DATABASE_URL automatically when you attach a Postgres plugin
# DATABASE_URL=  ← set by Railway automatically

# Railway injects REDIS_URL automatically when you attach a Redis plugin
# REDIS_URL=  ← set by Railway automatically

# Allow TypeORM to create/update tables on first deploy (disable after first deploy)
DB_SYNC=true

# Set to true on first deploy only — runs the database seed
RUN_SEED=true

# ── FRONTEND SERVICE ─────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000

# Must match your Railway backend service's public URL
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app/api/v1
